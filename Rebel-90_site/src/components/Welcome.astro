---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
---

<div id="container">
	<nav class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] w-[90%] max-w-4xl">
    <div class="bg-black/20 backdrop-blur-lg border border-white/10 px-8 py-4 rounded-full flex justify-between items-center">
      
      <span class="text-white tracking-tighter text-xl italic uppercase">REBEL-9</span>

      <div class="hidden md:flex gap-8 text-[10px] uppercase tracking-[0.3em] font-bold text-neutral-400">
        <a href="#" class="hover:text-white transition-colors">Drops</a>
        <a href="#" class="hover:text-white transition-colors">Archive</a>
        <a href="#" class="hover:text-white transition-colors">Mission</a>
      </div>

      <div class="flex gap-6 items-center">
        <button class="hover:scale-110 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        </button>
        <button id="cart-nav-btn" class="relative group">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          <span class="absolute -top-1 -right-1 bg-white text-black text-[8px] font-bold px-1.5 rounded-full">0</span>
        </button>
      </div>

    </div>
</nav>
</div>
